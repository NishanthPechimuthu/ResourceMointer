<div class="min-h-screen flex-center">
    <div class="glass-panel" style="width: 100%; max-width: 420px; padding: 2.5rem; text-align: center;">
        
        <div style="margin-bottom: 2rem;">
            <h1 style="font-size: 1.8rem; font-weight: 700; margin-bottom: 0.5rem; background: linear-gradient(135deg, var(--text-primary), var(--accent-primary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Two-Step Verification</h1>
            <p style="color: var(--text-secondary); font-size: 0.95rem;">Enter the code from your Authenticator app</p>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div style="background: rgba(239, 68, 68, 0.1); border: 1px solid var(--error-color); color: var(--error-color); padding: 0.75rem; border-radius: 8px; margin-bottom: 1.5rem; font-size: 0.9rem;">
                <%= error %>
            </div>
        <% } %>

        <form action="/auth/totp" method="POST" style="text-align: left;">
            <div class="input-group">
                <label for="token" class="input-label">6-Digit Code</label>
                <input type="text" id="token" name="token" class="input-field" placeholder="123456" required autocomplete="one-time-code" pattern="[0-9]{6}" maxlength="6" style="text-align: center; letter-spacing: 0.5rem; font-size: 1.25rem;" autofocus>
            </div>

            <button type="submit" class="btn-primary" style="margin-top: 1rem;">
                Verify Code
            </button>
        </form>
        
        <div style="margin-top: 2rem; font-size: 0.85rem; color: var(--text-secondary);">
            <a href="/auth/login" style="color: var(--accent-primary); text-decoration: none;">Cancel and go back</a>
        </div>
    </div>
</div>
