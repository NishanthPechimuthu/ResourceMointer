<div class="dashboard-wrapper container">
    
    <header class="dashboard-header glass-panel flex-center" style="justify-content: space-between; padding: 1.5rem 2rem; margin-top: 2rem; margin-bottom: 2rem;">
        <div>
            <h1 style="font-size: 1.8rem; font-weight: 700; background: linear-gradient(135deg, var(--text-primary), var(--accent-primary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                <span class="material-symbols-outlined" style="font-size: 2rem; vertical-align: bottom; margin-right: 0.25rem;">dashboard</span>
                NP Dashboard
            </h1>
            <p style="color: var(--text-secondary); font-size: 0.95rem; margin-top: 0.25rem;">Welcome back, <%= user.username %></p>
        </div>
        <div>
            <a href="/auth/logout" class="btn-primary" style="text-decoration: none; display: inline-flex; align-items: center; padding: 0.5rem 1.5rem; font-size: 0.9rem;">
                <span class="material-symbols-outlined" style="font-size: 1.2rem;">logout</span>
                Logout
            </a>
        </div>
    </header>

    <div class="dashboard-grid">
        <!-- System Info Card -->
        <div class="stat-card glass-panel">
            <h3 class="card-title">
                <span class="material-symbols-outlined" style="color: var(--accent-primary);">computer</span>
                System Information
            </h3>
            <div class="stat-row">
                <span class="stat-label">Hostname</span>
                <span class="stat-value" id="sys-hostname">Loading...</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Operating System</span>
                <span class="stat-value" id="sys-os">Loading...</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Kernel</span>
                <span class="stat-value" id="sys-kernel">Loading...</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Uptime</span>
                <span class="stat-value" id="sys-uptime">Loading...</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Public IP</span>
                <span class="stat-value" id="sys-public-ip">Loading...</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Private IP</span>
                <span class="stat-value" id="sys-private-ip">Loading...</span>
            </div>
        </div>

        <!-- CPU Card -->
        <div class="stat-card glass-panel">
            <h3 class="card-title">
                <span class="material-symbols-outlined" style="color: var(--accent-primary);">memory</span>
                Processor
            </h3>
            <div class="stat-row">
                <span class="stat-label">Model</span>
                <span class="stat-value" id="cpu-model">Loading...</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Cores</span>
                <span class="stat-value" id="cpu-cores">Loading...</span>
            </div>
            <div class="stat-row" style="margin-top: 1.5rem;">
                <span class="stat-label" style="font-size: 1.2rem; font-weight: 600; color: var(--accent-secondary);">Current Load</span>
                <span class="stat-value" id="cpu-load" style="font-size: 1.5rem; font-weight: 700; color: white;">0.00%</span>
            </div>
        </div>

        <!-- RAM & Swap Card -->
        <div class="stat-card glass-panel">
            <h3 class="card-title">
                <span class="material-symbols-outlined" style="color: var(--accent-primary);">storage</span>
                Memory
            </h3>
            <div class="stat-row" style="margin-top: 1rem;">
                <span class="stat-label">RAM Usage</span>
                <span class="stat-value" id="ram-usage" style="font-size: 1.2rem; font-weight: 600; color: white;">Loading...</span>
            </div>
            <div class="stat-row" style="margin-top: 1rem;">
                <span class="stat-label">Swap Usage</span>
                <span class="stat-value" id="swap-usage" style="font-size: 1.2rem; font-weight: 600; color: var(--text-secondary);">Loading...</span>
            </div>
        </div>

        <!-- Network Card -->
        <div class="stat-card glass-panel">
            <h3 class="card-title">
                <span class="material-symbols-outlined" style="color: var(--accent-primary);">router</span>
                Network Traffic
            </h3>
            <div class="stat-row" style="margin-top: 1rem;">
                <span class="stat-label">Total Download (Rx)</span>
                <span class="stat-value" id="net-rx" style="font-size: 1.2rem; font-weight: 600; color: var(--success-color);">Loading...</span>
            </div>
            <div class="stat-row" style="margin-top: 1rem;">
                <span class="stat-label">Total Upload (Tx)</span>
                <span class="stat-value" id="net-tx" style="font-size: 1.2rem; font-weight: 600; color: var(--accent-primary);">Loading...</span>
            </div>
        </div>

        <!-- Database Health Card -->
        <div class="stat-card glass-panel">
            <h3 class="card-title">
                <span class="material-symbols-outlined" style="color: var(--accent-primary);">database</span>
                Database Health
            </h3>
            <div class="stat-row">
                <span class="stat-label">PostgreSQL</span>
                <span class="stat-value" id="db-version">Loading...</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Database Size</span>
                <span class="stat-value" id="db-size">Loading...</span>
            </div>
            <div class="stat-row" style="margin-top: 1rem;">
                <span class="stat-label" style="font-size: 1.2rem; font-weight: 600; color: var(--accent-secondary);">Active Connections</span>
                <span class="stat-value" id="db-connections" style="font-size: 1.5rem; font-weight: 700; color: white;">0</span>
            </div>
        </div>

        <!-- Security & Nginx Card -->
        <div class="stat-card glass-panel">
            <h3 class="card-title">
                <span class="material-symbols-outlined" style="color: var(--accent-primary);">security</span>
                Security & Nginx
            </h3>
            <div id="sec-error-container" style="display: none; padding: 0.5rem; background: rgba(255, 204, 0, 0.1); color: var(--warning-color); border: 1px solid var(--warning-color); border-radius: 8px; font-size: 0.85rem; margin-bottom: 1rem;">
                <!-- Error msg goes here -->
            </div>
            <div class="stat-row">
                <span class="stat-label">Failed Requests</span>
                <span class="stat-value" id="sec-failed" style="color: var(--error-color); font-weight: 700;">0</span>
            </div>
            <div class="stat-row">
                <span class="stat-label">Bot Probes (.env/.git)</span>
                <span class="stat-value" id="sec-probes">0</span>
            </div>
            <div style="margin-top: 1rem;">
                <span class="stat-label" style="display: block; margin-bottom: 0.5rem;">Top Attacker IPs (Sample)</span>
                <ul id="sec-top-ips" style="list-style: none; padding: 0; font-size: 0.85rem; color: var(--text-secondary);">
                    <li>Loading...</li>
                </ul>
            </div>
        </div>
        
        <!-- Quick Links Card -->
        <div class="stat-card glass-panel" style="grid-column: span auto; display: flex; flex-direction: column;">
            <h3 class="card-title">
                <span class="material-symbols-outlined" style="color: var(--accent-primary);">link</span>
                Quick Links
            </h3>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; flex-grow: 1;">
                <a href="https://n8n.nishanth.qzz.io" target="_blank" class="btn-primary" style="text-align: center; text-decoration: none; display: flex; align-items: center; justify-content: center; font-size: 0.9rem;">
                    <span class="material-symbols-outlined" style="font-size: 1.1rem;">hub</span>
                    n8n
                </a>
                <a href="https://pgadmin.nishanth.qzz.io" target="_blank" class="btn-primary" style="text-align: center; text-decoration: none; display: flex; align-items: center; justify-content: center; font-size: 0.9rem;">
                    <span class="material-symbols-outlined" style="font-size: 1.1rem;">admin_panel_settings</span>
                    pgAdmin
                </a>
                <a href="#" class="btn-primary" style="text-align: center; text-decoration: none; display: flex; align-items: center; justify-content: center; font-size: 0.9rem;" onclick="alert('SSH Command: ssh ubuntu@ip')">
                    <span class="material-symbols-outlined" style="font-size: 1.1rem;">terminal</span>
                    SSH
                </a>
                <a href="#" class="btn-primary" style="text-align: center; text-decoration: none; display: flex; align-items: center; justify-content: center; font-size: 0.9rem;">
                    <span class="material-symbols-outlined" style="font-size: 1.1rem;">description</span>
                    Docs
                </a>
            </div>
        </div>

        <!-- Docker Section (Full width in grid) -->
        <div class="stat-card glass-panel" style="grid-column: 1 / -1; margin-bottom: 2rem;">
            <h3 class="card-title">
                <span class="material-symbols-outlined" style="color: var(--accent-primary);">dns</span>
                Services & Docker Containers
            </h3>
            <div style="overflow-x: auto;">
                <table class="data-table" style="width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr>
                            <th style="text-align: left; padding: 1rem; border-bottom: 1px solid var(--border-color); color: var(--text-secondary); font-weight: 500;">Status</th>
                            <th style="text-align: left; padding: 1rem; border-bottom: 1px solid var(--border-color); color: var(--text-secondary); font-weight: 500;">Container Name</th>
                            <th style="text-align: left; padding: 1rem; border-bottom: 1px solid var(--border-color); color: var(--text-secondary); font-weight: 500;">CPU Usage</th>
                            <th style="text-align: left; padding: 1rem; border-bottom: 1px solid var(--border-color); color: var(--text-secondary); font-weight: 500;">RAM Usage</th>
                            <th style="text-align: left; padding: 1rem; border-bottom: 1px solid var(--border-color); color: var(--text-secondary); font-weight: 500;">Restarts</th>
                        </tr>
                    </thead>
                    <tbody id="docker-table-body">
                        <tr>
                            <td colspan="5" style="text-align: center; padding: 2rem; color: var(--text-secondary);">Loading container data...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="/js/dashboard.js"></script>
