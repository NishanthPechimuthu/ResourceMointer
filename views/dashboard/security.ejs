<div class="dashboard-wrapper container">
    <header class="dashboard-header glass-panel flex-center" style="justify-content: space-between; padding: 1.5rem 2rem; margin-top: 2rem; margin-bottom: 2rem;">
        <div>
            <h1 style="font-size: 1.8rem; font-weight: 700; background: linear-gradient(135deg, var(--text-primary), var(--accent-primary)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                <span class="material-symbols-outlined" style="font-size: 2rem; vertical-align: bottom; margin-right: 0.25rem;">security</span>
                Security Analytics
            </h1>
            <p style="color: var(--text-secondary); font-size: 0.95rem; margin-top: 0.25rem;">Autonomous Intrusion Detection &amp; IP Blocking Engine</p>
        </div>
        <div style="display: flex; gap: 0.75rem; align-items: center;">
            <span id="engine-status-badge" style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.4rem 1rem;border-radius:99px;font-size:0.8rem;font-weight:600;background:rgba(16,185,129,0.15);color:#10b981;border:1px solid rgba(16,185,129,0.3);">
                <span style="width:8px;height:8px;border-radius:50%;background:#10b981;display:inline-block;animation:pulse 2s infinite;"></span>
                Engine Active
            </span>
            <a href="/dashboard" class="btn-primary" style="text-decoration: none; display: inline-flex; align-items: center; padding: 0.5rem 1.5rem; font-size: 0.9rem;">
                <span class="material-symbols-outlined" style="font-size: 1.2rem;">arrow_back</span>
                Dashboard
            </a>
        </div>
    </header>

    <!-- Summary Stats Row -->
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:1.5rem;">
        <div class="stat-card glass-panel" style="padding:1.25rem;text-align:center;">
            <div id="stat-total-bans" style="font-size:2rem;font-weight:700;color:var(--error-color);">—</div>
            <div style="font-size:0.8rem;color:var(--text-secondary);margin-top:0.25rem;">Active Bans</div>
        </div>
        <div class="stat-card glass-panel" style="padding:1.25rem;text-align:center;">
            <div id="stat-total-attackers" style="font-size:2rem;font-weight:700;color:var(--warning-color);">—</div>
            <div style="font-size:0.8rem;color:var(--text-secondary);margin-top:0.25rem;">Known Attackers</div>
        </div>
        <div class="stat-card glass-panel" style="padding:1.25rem;text-align:center;">
            <div id="stat-recent-attacks" style="font-size:2rem;font-weight:700;color:var(--accent-primary);">—</div>
            <div style="font-size:0.8rem;color:var(--text-secondary);margin-top:0.25rem;">Attacks (Last 50)</div>
        </div>
        <div class="stat-card glass-panel" style="padding:1.25rem;text-align:center;">
            <div id="stat-auto-banned" style="font-size:2rem;font-weight:700;color:#f97316;">—</div>
            <div style="font-size:0.8rem;color:var(--text-secondary);margin-top:0.25rem;">Auto-Banned Today</div>
        </div>
    </div>

    <div class="dashboard-grid">

        <!-- ================================================================
             ATTACKERS TABLE (with live threat score + Ban Now button)
             ================================================================ -->
        <div class="stat-card glass-panel" style="grid-column: span 2;">
            <h3 class="card-title">
                <span class="material-symbols-outlined" style="color:var(--warning-color);">person_alert</span>
                Known Attackers &amp; Threat Scores
                <span style="font-size:0.75rem;font-weight:400;color:var(--text-secondary);margin-left:0.5rem;">Auto-ban triggers at score ≥ 40 / hr</span>
            </h3>
            <div style="overflow-x:auto;">
                <table class="data-table" style="width:100%;border-collapse:collapse;">
                    <thead>
                        <tr>
                            <th style="text-align:left;padding:0.75rem 1rem;border-bottom:1px solid var(--border-color);color:var(--text-secondary);font-weight:500;">IP Address</th>
                            <th style="text-align:left;padding:0.75rem 1rem;border-bottom:1px solid var(--border-color);color:var(--text-secondary);font-weight:500;">Total Score</th>
                            <th style="text-align:left;padding:0.75rem 1rem;border-bottom:1px solid var(--border-color);color:var(--text-secondary);font-weight:500;">Score (1h)</th>
                            <th style="text-align:left;padding:0.75rem 1rem;border-bottom:1px solid var(--border-color);color:var(--text-secondary);font-weight:500;">Offenses</th>
                            <th style="text-align:left;padding:0.75rem 1rem;border-bottom:1px solid var(--border-color);color:var(--text-secondary);font-weight:500;">Last Seen</th>
                            <th style="text-align:left;padding:0.75rem 1rem;border-bottom:1px solid var(--border-color);color:var(--text-secondary);font-weight:500;">Status</th>
                            <th style="text-align:right;padding:0.75rem 1rem;border-bottom:1px solid var(--border-color);color:var(--text-secondary);font-weight:500;">Action</th>
                        </tr>
                    </thead>
                    <tbody id="attackers-table-body">
                        <tr><td colspan="7" style="text-align:center;padding:2rem;color:var(--text-secondary);">Loading attackers...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- ================================================================
             ACTIVE BANS TABLE
             ================================================================ -->
        <div class="stat-card glass-panel" style="grid-column: span 2;">
            <h3 class="card-title">
                <span class="material-symbols-outlined" style="color:var(--error-color);">gavel</span>
                Active System Bans
            </h3>
            <div style="overflow-x:auto;">
                <table class="data-table" style="width:100%;border-collapse:collapse;">
                    <thead>
                        <tr>
                            <th style="text-align:left;padding:0.75rem 1rem;border-bottom:1px solid var(--border-color);color:var(--text-secondary);font-weight:500;">IP Address</th>
                            <th style="text-align:left;padding:0.75rem 1rem;border-bottom:1px solid var(--border-color);color:var(--text-secondary);font-weight:500;">Reason</th>
                            <th style="text-align:left;padding:0.75rem 1rem;border-bottom:1px solid var(--border-color);color:var(--text-secondary);font-weight:500;">Ban Type</th>
                            <th style="text-align:left;padding:0.75rem 1rem;border-bottom:1px solid var(--border-color);color:var(--text-secondary);font-weight:500;">Expires</th>
                            <th style="text-align:right;padding:0.75rem 1rem;border-bottom:1px solid var(--border-color);color:var(--text-secondary);font-weight:500;">Action</th>
                        </tr>
                    </thead>
                    <tbody id="bans-table-body">
                        <tr><td colspan="5" style="text-align:center;padding:2rem;color:var(--text-secondary);">Loading bans...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- ================================================================
             MANUAL OVERRIDE PANEL
             ================================================================ -->
        <div class="stat-card glass-panel" style="display:flex;flex-direction:column;gap:1.5rem;">
            <h3 class="card-title">
                <span class="material-symbols-outlined" style="color:var(--accent-primary);">tune</span>
                Manual Overrides
            </h3>

            <div>
                <h4 style="margin-bottom:0.5rem;color:var(--text-primary);font-weight:500;">🚫 Block IP (Permanent Blacklist)</h4>
                <div style="display:flex;gap:0.5rem;margin-bottom:0.5rem;">
                    <input type="text" id="block-ip" class="input-field" placeholder="1.2.3.4" style="flex-grow:1;padding:0.5rem;">
                    <button class="btn-primary" id="btn-block-ip" style="width:auto;padding:0.5rem 1rem;background:var(--error-color);">Block</button>
                </div>
                <input type="text" id="block-reason" class="input-field" placeholder="Reason (optional)" style="width:100%;padding:0.5rem;box-sizing:border-box;">
            </div>

            <div>
                <h4 style="margin-bottom:0.5rem;color:var(--text-primary);font-weight:500;">✅ Whitelist IP (Never Ban)</h4>
                <div style="display:flex;gap:0.5rem;">
                    <input type="text" id="whitelist-ip" class="input-field" placeholder="1.2.3.4" style="flex-grow:1;padding:0.5rem;">
                    <button class="btn-primary" id="btn-whitelist-ip" style="width:auto;padding:0.5rem 1rem;background:var(--success-color);">Allow</button>
                </div>
            </div>

            <div id="override-status" style="display:none;padding:0.75rem;border-radius:8px;font-size:0.85rem;"></div>
        </div>

        <!-- ================================================================
             RECENT MALICIOUS REQUESTS
             ================================================================ -->
        <div class="stat-card glass-panel" style="grid-column: span 2;">
            <h3 class="card-title">
                <span class="material-symbols-outlined" style="color:var(--warning-color);">radar</span>
                Recent Malicious Requests
            </h3>
            <div style="overflow-x:auto;max-height:400px;">
                <table class="data-table" style="width:100%;border-collapse:collapse;">
                    <thead>
                        <tr>
                            <th style="text-align:left;padding:0.75rem 1rem;border-bottom:1px solid var(--border-color);color:var(--text-secondary);font-weight:500;position:sticky;top:0;background:var(--bg-card);">Time</th>
                            <th style="text-align:left;padding:0.75rem 1rem;border-bottom:1px solid var(--border-color);color:var(--text-secondary);font-weight:500;position:sticky;top:0;background:var(--bg-card);">IP Address</th>
                            <th style="text-align:left;padding:0.75rem 1rem;border-bottom:1px solid var(--border-color);color:var(--text-secondary);font-weight:500;position:sticky;top:0;background:var(--bg-card);">Request URL</th>
                            <th style="text-align:left;padding:0.75rem 1rem;border-bottom:1px solid var(--border-color);color:var(--text-secondary);font-weight:500;position:sticky;top:0;background:var(--bg-card);">Score</th>
                        </tr>
                    </thead>
                    <tbody id="attacks-table-body">
                        <tr><td colspan="4" style="text-align:center;padding:2rem;color:var(--text-secondary);">Loading attack data...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
}
.threat-bar {
    height: 6px;
    border-radius: 3px;
    background: var(--border-color);
    margin-top: 4px;
    overflow: hidden;
}
.threat-bar-fill {
    height: 100%;
    border-radius: 3px;
    transition: width 0.4s ease;
}
</style>

<script src="/js/security.js"></script>
